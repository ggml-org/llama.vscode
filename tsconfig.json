{
	"compilerOptions": {
	  "target": "ES2020",
	  "module": "commonjs",
	  "rootDir": "src",
	  "outDir": "dist",
	  "lib": ["ES2020", "DOM"],
	  "types": ["node", "vscode"],
	  "strict": true,
	  "moduleResolution": "node",
	  "ignoreDeprecations": "6.0",
	  "sourceMap": true,
	  "resolveJsonModule": true,
	  "esModuleInterop": true
	},
	"include": ["src/**/*"],
	"exclude": ["ui/**/*", "node_modules", "dist"]
  }
  